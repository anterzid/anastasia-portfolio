---
import {
  socialLinks,
  navItems,
  aboutIntro,
  aboutHighlights,
  experience,
  projects,
  talks,
  skillGroups,
} from "../data/portfolio";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
	<link rel="icon" type="image/png" href="/favicon.png" />
    <title>Anastasia Terzidou | Data Systems & Product Strategy</title>
    <meta
      name="description"
      content="I design data systems that businesses rely on for real decisions, bridging product, data, and operations to build reliable reporting and revenue platforms."
    />
    <link rel="canonical" href="https://anastasiaterzidou.gr" />
    <!-- Open Graph -->
    <meta property="og:title" content="Anastasia Terzidou | Data Systems & Product Strategy" />
    <meta property="og:description" content="I design data systems that businesses rely on for real decisions, bridging product, data, and operations to build reliable reporting and revenue platforms." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://anastasiaterzidou.gr" />
    <meta property="og:image" content="https://anastasiaterzidou.gr/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Anastasia Terzidou | Data Systems & Product Strategy" />
    <meta name="twitter:description" content="I design data systems that businesses rely on for real decisions, bridging product, data, and operations to build reliable reporting and revenue platforms." />
    <meta name="twitter:image" content="https://anastasiaterzidou.gr/og-image.png" />

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;500;600;700&display=swap"
	rel="stylesheet"
	/>

    <style>
      :root {
        --bg: #f6f1eb;
        --bg2: #ece5f1;
        --surface: #fffdfb;
        --text: #24303a;
        --muted: #66707c;
        --line: #e7ddd2;
        --primary: #7b6d96;
        --secondary: #8aa7a0;
        --shadow: 0 20px 60px rgba(30, 36, 44, 0.07);
        --radius: 34px;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: linear-gradient(
          140deg,
          #f6f1eb 0%,
          #efe8f3 42%,
          #f6f1eb 100%
        );
        color: var(--text);
        line-height: 1.65;
      }

      h1, h2, h3 {
        font-family: "Lora", Georgia, "Times New Roman", serif;
        margin: 0;
        color: #18202a;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1100px, calc(100% - 40px));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(10px);
        background: rgba(246, 241, 235, 0.84);
        border-bottom: 1px solid rgba(231, 221, 210, 0.78);
      }

      .site-header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 0;
        gap: 20px;
      }

      .brand {
        font-size: 0.82rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #5f6771;
        font-weight: 700;
      }

      .nav {
        display: flex;
        flex-wrap: nowrap;
        gap: 18px;
        font-size: 0.88rem;
        color: var(--muted);
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-width: none;
        align-items: center;
      }

      .nav::-webkit-scrollbar {
        display: none;
      }

      .nav a {
        display: inline-flex;
        align-items: center;
        padding: 0;
        border-radius: 0;
        background: transparent;
        border: none;
        color: #5f6771;
        line-height: 1.2;
        transition: color 0.18s ease, opacity 0.18s ease;
        box-shadow: none;
        white-space: nowrap;
      }

      .nav a:hover {
        color: #2f3944;
        opacity: 1;
      }

      .nav a::after {
        content: "";
        display: block;
        width: 0;
        height: 1px;
        background: rgba(123, 109, 150, 0.55);
        transition: width 0.18s ease;
        margin-top: 4px;
      }

      .nav a:hover::after {
        width: 100%;
      }

      .hero {
        position: relative;
        padding: 80px 0 56px;
        overflow: hidden;
      }

      .hero::before {
        content: "";
        position: absolute;
        width: 460px;
        height: 460px;
        right: -120px;
        top: -60px;
        background: radial-gradient(circle, rgba(225, 215, 203, 0.52) 0%, rgba(225, 215, 203, 0) 72%);        pointer-events: none;
      }

      .hero::after {
        content: "";
        position: absolute;
        width: 380px;
        height: 380px;
        left: -120px;
        bottom: -120px;
        background: radial-gradient(circle, rgba(228, 220, 239, 0.46) 0%, rgba(228, 220, 239, 0) 72%);        pointer-events: none;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 72px;
        align-items: center;
        position: relative;
        z-index: 1;
      }

      .eyebrow {
        display: inline-block;
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(255, 253, 251, 0.86);
        border: 1px solid rgba(231, 221, 210, 0.92);
        color: #6a7280;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 700;
        margin-bottom: 24px;
      }

      .hero h1 {
        font-size: clamp(3.2rem, 6vw, 5rem);
        line-height: 1.02;
        margin-bottom: 18px;
      }

      .hero-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #2f3944;
        margin-bottom: 24px;
      }

      .hero-motto {
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 1rem;
        color: #6b7280;
        font-style: italic;
        margin-bottom: 18px;
        letter-spacing: 0.01em;
      }

      .hero-motto::before {
        content: "";
        width: 42px;
        height: 1px;
        background: linear-gradient(
          90deg,
          rgba(123, 109, 150, 0.8),
          rgba(123, 109, 150, 0.18)
        );
        flex-shrink: 0;
      }

      .hero-text {
        font-size: 1.1rem;
        color: var(--muted);
        max-width: 58ch;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
      }

      .btn {
        padding: 14px 20px;
        border-radius: 999px;
        font-weight: 600;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
        display: inline-flex;
        align-items: center;
      }

      .btn:hover,
      .card:hover,
      .skill:hover {
        transform: translateY(-2px);
      }

      .btn-primary {
        background: var(--primary);
        color: white;
        box-shadow: var(--shadow);
      }

      .btn-secondary {
        background: var(--surface);
        border: 1px solid var(--line);
        color: var(--text);
      }

      .photo-wrap {
        position: relative;
      }

      .photo-wrap::before {
        content: "";
        position: absolute;
        inset: 40px -20px -30px 30px;
        border-radius: 50px;
        background: linear-gradient(
          135deg,
          rgba(123, 109, 150, 0.25),
          rgba(138, 167, 160, 0.18)
        );
        filter: blur(18px);
        z-index: 0;
      }

      .photo-card {
        position: relative;
        background: transparent;
        border: none;
        border-radius: 40px;
        padding: 0;
        box-shadow: none;
      }

      .photo-card img {
        display: block;
        width: 100%;
        height: 540px;
        object-fit: cover;
        border-radius: 30px;
      }

      section {
        padding: 56px 0;
      }

      .section-intro {
        margin-bottom: 24px;
      }

      .section-kicker {
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 700;
        margin-bottom: 12px;
      }

      .section-title {
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        line-height: 1.1;
        letter-spacing: -0.01em;
      }

      .story-card {
        padding: 40px;
        background: linear-gradient(
          180deg,
          rgba(255,253,251,0.98),
          rgba(245,240,248,0.96)
        );
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: 0 20px 60px rgba(30, 36, 44, 0.08);
      }

      .story-text {
        color: var(--muted);
        font-size: 1.02rem;
      }

      .publications-list {
        display: grid;
        gap: 18px;
      }

      .publication-item {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 28px 30px;
      }

      .publication-authors {
        color: var(--muted);
        font-size: 0.95rem;
        margin-bottom: 10px;
      }

      .publication-title {
        font-family: "Lora", Georgia, "Times New Roman", serif;
        font-size: 1.2rem;
        line-height: 1.35;
        margin-bottom: 10px;
        color: #18202a;
      }

      .publication-meta {
        color: var(--muted);
        font-size: 0.98rem;
        line-height: 1.7;
      }

      .publication-meta em {
        color: #1f2933;
        font-style: italic;
      }

      .publication-doi {
        display: inline-block;
        margin-top: 10px;
        color: var(--primary);
        font-weight: 600;
        word-break: break-word;
      }

      .publication-doi:hover {
        text-decoration: underline;
      }

      .presentation-section {
        margin-top: 22px;
      }

      .subsection-title {
        font-family: "Lora", Georgia, "Times New Roman", serif;
        font-size: 1.5rem;
        line-height: 1.3;
        color: #18202a;
        margin: 0 0 16px;
      }

      .presentation-item {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 28px 30px;
      }

      .presentation-meta {
        color: var(--muted);
        font-size: 0.98rem;
        line-height: 1.7;
      }

      .presentation-meta em {
        color: #1f2933;
        font-style: italic;
      }

      .featured-talk-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(
          135deg,
          rgba(255,253,251,0.98) 0%,
          rgba(245,240,248,0.98) 52%,
          rgba(244,248,246,0.98) 100%
        );
        border: 1px solid rgba(123, 109, 150, 0.14);
        border-radius: calc(var(--radius) + 6px);
        box-shadow: 0 24px 68px rgba(30, 36, 44, 0.1);
        padding: 34px 36px;
      }

      .featured-talk-card::before {
        content: "";
        position: absolute;
        top: -56px;
        right: -56px;
        width: 190px;
        height: 190px;
        background: radial-gradient(circle, rgba(123, 109, 150, 0.16) 0%, rgba(123, 109, 150, 0) 72%);
        pointer-events: none;
      }

      .featured-talk-card::after {
        content: "";
        position: absolute;
        bottom: -60px;
        left: -44px;
        width: 180px;
        height: 180px;
        background: radial-gradient(circle, rgba(138, 167, 160, 0.14) 0%, rgba(138, 167, 160, 0) 72%);
        pointer-events: none;
      }

      .featured-talk-kicker {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(255, 253, 251, 0.82);
        border: 1px solid rgba(123, 109, 150, 0.14);
        color: #6b5f82;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 700;
        margin-bottom: 18px;
      }

      .featured-talk-card .publication-title,
      .featured-talk-card .presentation-meta,
      .featured-talk-card .story-text,
      .featured-talk-card .publication-doi {
        position: relative;
        z-index: 1;
      }

      .featured-talk-card .publication-title {
        font-size: clamp(1.45rem, 2.4vw, 2rem);
        line-height: 1.24;
        margin-bottom: 14px;
      }

      .featured-talk-card .presentation-meta {
        margin-bottom: 14px;
      }

      .featured-talk-card .story-text {
        max-width: 70ch;
        margin-bottom: 0;
      }

      .featured-talk-card .publication-doi {
        margin-top: 18px;
      }

	  .highlight-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 28px;
    }

		.mini-card {
      position: relative;
      background: linear-gradient(
        180deg,
        rgba(255,253,251,0.98),
        rgba(246,240,248,0.98)
      );
      border: 1px solid var(--line);
      border-radius: 28px;
      padding: 26px;
      box-shadow: 0 14px 40px rgba(30, 36, 44, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .mini-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 22px 55px rgba(30, 36, 44, 0.12);
    }

		.mini-card h3 {
		font-size: 1.2rem;
		margin-bottom: 10px;
		}

		.bullet-list {
		margin: 16px 0 0;
		padding-left: 20px;
		color: var(--muted);
		}

		.bullet-list li {
		margin-bottom: 10px;
		line-height: 1.65;
		}


      .experience-list {
        display: grid;
        gap: 18px;
      }

      .projects-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
      }

      .project-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(255,253,251,0.98), rgba(248,244,249,0.98));
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: 0 18px 48px rgba(30, 36, 44, 0.08);
        padding: 32px;
        min-height: 220px;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
      }

      .project-card::before {
        content: "";
        position: absolute;
        top: -40px;
        right: -40px;
        width: 140px;
        height: 140px;
        background: radial-gradient(circle, rgba(123, 109, 150, 0.12) 0%, rgba(123, 109, 150, 0) 72%);        pointer-events: none;
      }

      .project-card::after {
        content: "";
        position: absolute;
        bottom: -40px;
        left: -40px;
        width: 130px;
        height: 130px;
        background: radial-gradient(circle, rgba(138, 167, 160, 0.12) 0%, rgba(138, 167, 160, 0) 72%);
        pointer-events: none;
      }

      .project-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 58px rgba(30, 36, 44, 0.1);
      }

      .project-card h3 {
        position: relative;
        z-index: 1;
        margin-bottom: 14px;
      }

      .project-card .story-text {
        position: relative;
        z-index: 1;
      }

      .card {
        padding: 30px;
      }

      .card-meta {
        color: var(--muted);
        font-size: 0.92rem;
        margin-bottom: 10px;
      }

      .card-org {
        color: #4f7f79;
        font-weight: 600;
        margin: 6px 0 12px;
      }

      .skills {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .skills-layout {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
      }

      .skills-panel {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 28px 30px;
      }

      .skills-panel-title {
        font-family: "Lora", Georgia, "Times New Roman", serif;
        font-size: 1.3rem;
        line-height: 1.3;
        color: #18202a;
        margin: 0 0 16px;
      }

      .skill {
        padding: 12px 18px;
        background: rgba(255, 253, 251, 0.94);
        border: 1px solid var(--line);
        border-radius: 999px;
        box-shadow: 0 8px 22px rgba(30, 36, 44, 0.045);
        font-weight: 600;
        color: #44505d;
        transition: transform 0.18s ease;
      }

      .contact-box {
        background: #27313a;
        color: white;
        border-radius: 40px;
        padding: 42px;
        box-shadow: 0 24px 60px rgba(26, 32, 44, 0.16);
      }

      .contact-box p {
        color: rgba(255, 255, 255, 0.78);
      }

      .contact-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
      }

      .contact-actions a {
        border-radius: 999px;
        padding: 14px 18px;
        font-weight: 600;
      }

      .contact-actions .email {
        background: white;
        color: #1f2933;
      }

      .contact-actions .outline {
        border: 1px solid rgba(255, 255, 255, 0.24);
        color: white;
      }

      @media (max-width: 900px) {
        .hero-grid {
          grid-template-columns: 1fr;
        }

        .photo-card img {
          height: 420px;
        }

        .nav {
          display: flex;
          overflow-x: auto;
          flex-wrap: nowrap;
          gap: 14px;
          padding-bottom: 4px;
          scrollbar-width: none;
        }

        .nav::-webkit-scrollbar {
          display: none;
        }

        .hero {
          padding-top: 56px;
        }

        .skills-layout {
          grid-template-columns: 1fr;
        }

        .projects-list {
          grid-template-columns: 1fr;
        }

        .highlight-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <div class="brand">Anastasia Terzidou</div>
        <nav class="nav">
          {navItems.map(({ label, href }) => (
            <a href={href}>{label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <section class="hero" id="home">
        <div class="container hero-grid">
          <div>
            <div class="eyebrow">Data Systems — Product Strategy — Analytics</div>
            <h1>Anastasia Terzidou</h1>
            <div class="hero-title">
              I design data systems that businesses rely on for real decisions.
            </div>
            <p class="hero-motto">
              Bridging product, data, and operations to build reliable reporting and revenue systems.
            </p>
            <p class="hero-text">
              Focused on system reliability, data integrity, and decision-ready analytics for internal platforms and revenue environments.
            </p>

            <div class="button-row">
              <a
                class="btn btn-primary"
                href={socialLinks.linkedin}
                target="_blank"
                rel="noreferrer"
              >
                LinkedIn
              </a>
              <a class="btn btn-secondary" href={socialLinks.email}>Email</a>
              <a class="btn btn-secondary" href={socialLinks.github} target="_blank" rel="noreferrer">
                GitHub
              </a>
            </div>
          </div>

          <div class="photo-wrap">
            <div class="photo-card">
              <img src="/profilePhoto.png" alt="Portrait of Anastasia Terzidou" />
            </div>
          </div>
        </div>
      </section>

      <section id="about">
		<div class="container">
			<div class="section-intro">
			<div class="section-kicker">About</div>
			<h2 class="section-title">
				Shaped by systems thinking, product contribution and data-driven
				problem solving.
			</h2>
			</div>

			<div class="story-card">
			<p class="story-text">{aboutIntro}</p>
			</div>

			<div class="highlight-grid">
			{aboutHighlights.map((item) => (
				<article class="mini-card">
				<h3>{item.title}</h3>
				<p class="story-text">{item.text}</p>
				</article>
			))}
			</div>
		</div>
	 </section>

      <section id="experience">
		<div class="container">
			<div class="section-intro">
			<div class="section-kicker">Experience</div>
			<h2 class="section-title">Professional and academic trajectory</h2>
			</div>

			<div class="experience-list">
			{experience.map((item) => (
				<article class="card">
				<div class="card-meta">{item.period}</div>
				<h3>{item.title}</h3>
				<div class="card-org">{item.org}</div>
				<p class="story-text">{item.summary}</p>

				<ul class="bullet-list">
					{item.bullets.map((bullet) => (
					<li>{bullet}</li>
					))}
				</ul>
				</article>
			))}
			</div>
		</div>
	</section>

      <section id="projects">
        <div class="container">
          <div class="section-intro">
            <div class="section-kicker">Projects</div>
            <h2 class="section-title">Selected product and systems work</h2>
          </div>
          <div class="projects-list">
            {projects.map((item) => (
              <article class="project-card">
                <h3>{item.title}</h3>
                <p class="story-text">{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="talks">
        <div class="container">
          <div class="section-intro">
            <div class="section-kicker">Talks</div>
            <h2 class="section-title">Selected talks and speaking engagements</h2>
          </div>
          <div class="publications-list">
            {talks.map((item) => (
              <article class="featured-talk-card">
                <div class="featured-talk-kicker">Featured Speaking Engagement</div>
                <h3 class="publication-title">{item.title}</h3>
                <div class="presentation-meta">
                  <em>{item.role}</em> — {item.event}, {item.date}, {item.location}
                </div>
                <p class="story-text">{item.description}</p>
                <a class="publication-doi" href={item.link} target="_blank" rel="noreferrer">
                  View event
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="academic">
        <div class="container">
          <div class="section-intro">
            <div class="section-kicker">Academic Background</div>
            <h2 class="section-title">Research foundation in complex systems</h2>
          </div>
          <div class="story-card">
            <p class="story-text">
